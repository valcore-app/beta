# Public/oracle routing
NEXT_PUBLIC_ORACLE_URL=http://localhost:3101
ORACLE_INTERNAL_URL=http://localhost:3101
# Wallet chain metadata RPC (required for wallet/network context)
NEXT_PUBLIC_CHAIN_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
# Optional comma-separated failover RPC list for Starknet read/wait calls
NEXT_PUBLIC_CHAIN_RPC_FALLBACK_URLS=
# Read transport RPC used by viem/wagmi (same-origin proxy by default)
# NEXT_PUBLIC_CHAIN_READ_RPC_URL=/api/rpc

# NextAuth / wallet auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
WALLET_AUTH_SECRET=


# Auth database
AUTH_DATABASE_URL=postgresql://app_write:<password>@127.0.0.1:5432/valcore-avalanche-testnet
AUTH_DB_SSL_REJECT_UNAUTHORIZED=false

# OAuth providers (ops login)
GITHUB_ID=
GITHUB_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Oracle proxy API keys
ORACLE_ADMIN_API_KEY=
ORACLE_STRATEGIST_API_KEY=

# Optional wallet/session tuning
# WALLET_SESSION_TTL_SECONDS=86400
# WALLET_NONCE_TTL_SECONDS=300
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=valcore-dev
# NEXT_PUBLIC_STARKNET_TYPED_DATA_CHAIN_ID=0x534e5f5345504f4c4941
# NEXT_PUBLIC_STARKNET_WALLET_INSTALL_URL=https://chromewebstore.google.com/search/ready%20wallet
# NEXT_PUBLIC_STARKNET_NATIVE_TOKEN_ADDRESS=0x04718f5a0fc34cc1af16a1cdee98ffb20c31f5cd61d6ab07201858f4287c938d

# Optional public protocol constants
# NEXT_PUBLIC_PRINCIPAL_RATIO_BPS=8000
# NEXT_PUBLIC_STABLECOIN_DECIMALS=18
# NEXT_PUBLIC_MIN_DEPOSIT_STABLECOIN=50
# NEXT_PUBLIC_FAUCET_STABLECOIN_AMOUNT=200








